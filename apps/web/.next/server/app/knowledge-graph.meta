{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/knowledge-graph/layout,_N_T_/knowledge-graph/page,_N_T_/knowledge-graph"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/knowledge-graph/__PAGE__"
  ],
  "prefetchHints": {
    "hints": 64,
    "slots": {
      "children": {
        "hints": 96,
        "slots": {
          "children": {
            "hints": 160,
            "slots": null
          }
        }
      }
    }
  }
}